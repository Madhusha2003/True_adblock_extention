{
    "manifest_version": 3,
    "name": "True AD blocker",
    "version": "5.1",
    "description": "High-performance rule-based ad blocker with advanced scriptlet protections.",
    "author": "MadNir",
    "icons": {
        "128": "icons/icon128.png"
    },
    "permissions": [
        "declarativeNetRequest",
        "declarativeNetRequestFeedback",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "True AI Ad Blocker"
    },
    "options_page": "options.html",
    "background": {
        "service_worker": "background.js"
    },
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "ruleset_1",
                "enabled": true,
                "path": "rules.json"
            }
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "scriptlet.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        }
    ]
}